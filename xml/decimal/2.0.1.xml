 <name>decimal</name>
 <channel>pecl.php.net</channel>
 <summary>Arbitrary precision floating-point decimal</summary>
 <description>Correctly-rounded arbitrary precision decimal floating-point arithmetic in PHP</description>
 <lead>
  <name>Rudi Theunissen</name>
  <user>rtheunissen</user>
  <email>rtheunissen@php.net</email>
  <active>yes</active>
 </lead>
 <date>2026-04-11</date>
